# Environment Variables Configuration

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=your_resource_group_here
AZURE_ML_WORKSPACE=your_workspace_name_here
AZURE_TENANT_ID=your_tenant_id_here

# Azure ML Configuration
AZURE_ML_COMPUTE_TARGET=cpu-cluster
AZURE_ML_ENVIRONMENT_NAME=titanic-logistic-regression
AZURE_ML_EXPERIMENT_NAME=titanic-logistic-regression-exp

# Model Configuration
MODEL_PATH=./model/model.pkl
PREPROCESSOR_PATH=./model/preprocessor.pkl

# API Configuration
PORT=5000
DEBUG=False
LOG_LEVEL=INFO

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=titanic-logistic-regression

# Data Configuration
DATA_PATH=titanic.csv
TEST_SIZE=0.2
RANDOM_STATE=42

# Docker Configuration
REGISTRY_URL=your_registry_url_here
IMAGE_NAME=titanic-logistic-regression
IMAGE_TAG=latest

# Security
KEY_VAULT_NAME=your-keyvault-name
